# Neon Postgres — copy to .env and fill in your connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Where the local agent posts benchmark metrics (default: this server's /api/benchmark-runs).
BENCHMARK_API_BASE=http://127.0.0.1:3001

# Pipeline models recorded by the agent (must match agent/src/agent.py and providers table).
BENCHMARK_STT_MODEL=deepgram/nova-3
BENCHMARK_LLM_MODEL=xai/grok-4-1-fast-non-reasoning
BENCHMARK_TTS_MODEL=cartesia/sonic-3
